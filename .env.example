# ============================================================================
# Zuora SE Demo Data Agent configuration
#
# Copy this file to .env and fill in the values marked REQUIRED.
# ============================================================================

# --- app ---------------------------------------------------------------------
APP_NAME="Zuora SE Demo Data Agent"
APP_HOST=127.0.0.1
APP_PORT=8000
APP_BASE_URL=http://localhost:8000

# REQUIRED. Random, long string used to sign session cookies.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=change-me

# --- db ----------------------------------------------------------------------
# Default is a SQLite file under data/. Swap to Postgres later when you go
# multi-machine:  postgresql+psycopg://user:pass@host:5432/zuora_nightly
# DATABASE_URL=sqlite:///./data/app.db

# --- crypto ------------------------------------------------------------------
# REQUIRED. 44-character urlsafe-base64 Fernet key used to encrypt every
# stored Zuora client secret. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Rotating this key will make every stored Zuora secret unreadable.
MASTER_ENCRYPTION_KEY=

# --- auth --------------------------------------------------------------------
# Restrict login to one email domain. Empty = allow any Google account.
ALLOWED_EMAIL_DOMAIN=zuora.com

# Google OAuth client. Create at:
#   https://console.cloud.google.com/apis/credentials
# Authorized redirect URI MUST be: <APP_BASE_URL>/auth/callback
# e.g. http://localhost:8000/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Dev shortcut: when true, POST /auth/dev-login creates a fake user and logs
# you in without going through Google. Handy for testing; NEVER enable in prod.
DEV_AUTH_BYPASS=true

# --- Claude (Phase 2+) -------------------------------------------------------
# Shared API key used to run the skill on behalf of every user. Billed to this
# key regardless of who clicked "Run now". Create at:
#   https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
